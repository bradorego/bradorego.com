---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  
  const paths: any[] = [];
  
  allPosts.forEach(post => {
    if (post.data.aliases && post.data.aliases.length > 0) {
      post.data.aliases.forEach((alias: string) => {
        // Strip leading and trailing slashes safely without escape issues
        const cleanAlias = alias.split('/').filter(Boolean).join('/');
        if (cleanAlias) {
          paths.push({
            params: { alias: cleanAlias },
            props: { entry: post }
          });
        }
      });
    }
  });
  
  return paths;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Calculate read time
const wordCount = entry.body ? entry.body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Determine canonical URL from the actual post slug
const canonicalUrl = new URL(`/blog/${entry.id}`, Astro.site || 'https://bradorego.com').toString();

---

<Layout title={entry.data.title} description={entry.data.description || undefined} image={entry.data.image || undefined}>
  <!-- Inject canonical link to avoid duplicate content SEO penalty -->
  <link rel="canonical" href={canonicalUrl} slot="head" />
  
  <div class="container" style="max-width: 1140px; padding: 2rem 1.5rem 4rem;">
    <a href="/blog" class="btn btn-outline" style="margin-bottom: 2rem;">&larr; Back to Blog</a>
    
    <div class="card" style="overflow: hidden;">
      {entry.data.image && (
        <div style="width: 100%; max-height: 500px; background: var(--color-bg); display: flex; align-items: center; justify-content: center; border-bottom: 1px solid var(--color-border);">
          <img src={entry.data.image} alt={entry.data.title} style="width: 100%; height: 100%; max-height: 500px; object-fit: contain;" />
        </div>
      )}
      <div class="card-body">
        <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">{entry.data.title}</h1>
        <p style="color: var(--color-text-muted); margin-bottom: 2.5rem; font-family: var(--font-mono); font-size: 0.875rem;">
          {readingTime} minute read
        </p>
        
        {entry.data.lessonsLearned && entry.data.lessonsLearned.length > 0 && (
          <div class="tldnr">
            <h3>TL;DNR</h3>
            <ul>
              {entry.data.lessonsLearned.map((lesson: string) => (
                <li>{lesson}</li>
              ))}
            </ul>
          </div>
        )}
        
        <div class="content-body">
          <Content />
        </div>
        
        <div style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--color-border); font-family: var(--font-mono); font-size: 0.875rem; color: var(--color-text-muted);">
          {entry.data.date && <p style="margin-bottom: 1rem;">Posted on {new Date(entry.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>}
          
          {entry.data.categories && entry.data.categories.length > 0 && (
            <p style="margin-bottom: 0.5rem;">
              <strong style="color: var(--color-text);">Categories:</strong> 
              {entry.data.categories.map((category: string, index: number) => (
                <span>
                  <a href={`/categories/${category.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}>{category}</a>{index < entry.data.categories.length - 1 ? ', ' : ''}
                </span>
              ))}
            </p>
          )}
          
          {entry.data.tags && entry.data.tags.length > 0 && (
            <p>
              <strong style="color: var(--color-text);">Tags:</strong> 
              {entry.data.tags.map((tag: string, index: number) => (
                <span>
                  <a href={`/tags/${tag.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}>{tag}</a>{index < entry.data.tags.length - 1 ? ', ' : ''}
                </span>
              ))}
            </p>
          )}
        </div>
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  .content-body h2 { margin-top: 2.5rem; margin-bottom: 1rem; }
  .content-body h3, .content-body h4 { margin-top: 2rem; margin-bottom: 1rem; }
  .content-body p { margin-bottom: 1.5rem; font-size: 1.125rem; }
  .content-body ul, .content-body ol { margin-bottom: 1.5rem; padding-left: 1.5rem; font-size: 1.125rem; }
  .content-body li { margin-bottom: 0.5rem; }
  .content-body img { border-radius: var(--radius-md); margin: 2rem auto 0.5rem; display: block; max-width: 100%; box-shadow: var(--shadow-sm); }
  .image-caption { text-align: center; color: var(--color-text-muted); font-size: 0.875rem; margin-bottom: 2rem; display: block; font-style: italic; }
  .content-body pre { padding: 1rem; border-radius: var(--radius-md); overflow-x: auto; margin-bottom: 1.5rem; }
  .content-body code { font-family: var(--font-mono); background: var(--color-bg); padding: 0.2rem 0.4rem; border-radius: var(--radius-sm); font-size: 0.875em;}
  .content-body pre code { background: transparent; padding: 0; }
  .content-body blockquote { border-left: 4px solid var(--color-primary); padding-left: 1rem; font-style: italic; color: var(--color-text-muted); margin: 1.5rem 0; }
  
  /* Handle the existing raw HTML tldnr class from posts */
  .tldnr {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  .tldnr h3 {
    margin-top: 0;
    color: var(--color-primary);
  }
  .tldnr ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 0;
  }
  .tldnr li {
    margin-bottom: 0.5rem;
  }
</style>
