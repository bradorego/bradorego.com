---
import Layout from '../layouts/Layout.astro';
---
<Layout title="404: Page Not Found">
  <div class="container" style="max-width: 800px; padding: 4rem 1.5rem; text-align: center;">
    <h1 style="font-size: 6rem; margin-bottom: 0; color: var(--color-primary); line-height: 1;">404</h1>
    <h2 style="margin-bottom: 2rem;">Page Not Found</h2>
    
    <p style="font-size: 1.25rem; color: var(--color-text-muted); margin-bottom: 3rem;">
      Oops! It looks like the page you're looking for doesn't exist, has been moved, or is temporarily unavailable.
    </p>
    
    <a href="/" class="btn btn-outline" style="font-size: 1.125rem; padding: 0.75rem 2rem;">
      &larr; Return Home
    </a>
  </div>
</Layout>
