---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { 
  title, 
  description = "Brad has been helping companies from startup to Fortune 500 research, design, and build better products since 2008.",
  image = "https://bradorego.com/img/headshot.jpg"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Brad Orego" />
    
    <title>{title} | bradorego.com</title>
    
    <meta property="og:title" content={`${title} | bradorego.com`} />
    <meta property="og:type" content="website" />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={Astro.url} />
    
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} | bradorego.com`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar">
      <div class="container nav-container">
        <a class="brand" href="/">
          <h1>Brad Orego <span class="pronouns">(they/them)</span></h1>
          <h2>UX Leader. User Researcher. Coach. Dancer.</h2>
        </a>
        <div class="nav-actions">
          <a href="/coaching" class="btn btn-outline nav-btn">Coaching</a>
          <a href="https://cal.com/bradorego" class="btn btn-outline nav-btn">Meetings</a>
        </div>
      </div>
    </nav>
    
    <main class="main-content">
      <slot />
    </main>

    <footer class="footer">
      <div class="container text-center">
        <div class="social-links">
          <a href="mailto:hello@bradorego.com" aria-label="Email">
            <i class="ion-android-mail"></i>
          </a>
          <a href="https://twitter.com/bradorego" aria-label="Twitter">
            <i class="ion-social-twitter"></i>
          </a>
          <a href="https://github.com/bradorego" aria-label="GitHub">
            <i class="ion-social-github"></i>
          </a>
          <a href="https://instagram.com/bradorego" aria-label="Instagram">
            <i class="ion-social-instagram"></i>
          </a>
          <a href="https://linkedin.com/in/bradorego" aria-label="LinkedIn">
            <i class="ion-social-linkedin"></i>
          </a>
        </div>
        <div class="rochester-made">
          <a href="http://rochestermade.com" title="Rochester Made">
            <img alt="Rochester Made" src="https://rochestermade.com/media/images/rochester-made-dark-on-light.png" />
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  /* Navbar styles */
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(15, 17, 21, 0.85); /* var(--color-bg) with opacity */
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 0;
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  @media (max-width: 768px) {
    .nav-container {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }

  .brand h1 {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }
  
  .brand .pronouns {
    font-size: 1rem;
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .brand h2 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .nav-actions {
    display: flex;
    gap: 0.75rem;
    width: 100%;
  }

  @media (min-width: 769px) {
    .nav-actions {
      width: auto;
    }
  }
  
  .nav-btn {
    flex: 1;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
  }

  /* Main content area */
  .main-content {
    flex: 1;
    padding: 4rem 0;
  }

  /* Footer styles */
  .footer {
    padding: 3rem 0;
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .text-center {
    text-align: center;
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .social-links a {
    color: var(--color-text-muted);
    font-size: 1.75rem;
    transition: all var(--transition-normal);
  }

  .social-links a:hover {
    color: var(--color-primary);
  }

  .rochester-made img {
    height: 40px;
    margin: 0 auto;
    opacity: 0.7;
    transition: opacity var(--transition-normal);
  }

  .rochester-made a:hover img {
    opacity: 1;
  }
</style>
