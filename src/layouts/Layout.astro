---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { 
  title, 
  description = "Brad has been helping companies from startup to Fortune 500 research, design, and build better products since 2008.",
  image = "https://bradorego.com/img/headshot.jpg"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Brad Orego" />
    
    <title>{title} | bradorego.com</title>
    
    <meta property="og:title" content={`${title} | bradorego.com`} />
    <meta property="og:type" content="website" />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={Astro.url} />
    
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} | bradorego.com`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css" rel="stylesheet">
    <ClientRouter />
    <script is:inline>
      try {
        const a11ySettings = JSON.parse(localStorage.getItem('a11y') || '{}');
        if (a11ySettings.dyslexic) document.documentElement.setAttribute('data-a11y-dyslexic', 'true');
        if (a11ySettings.contrast) document.documentElement.setAttribute('data-a11y-contrast', 'true');
        if (a11ySettings.motion) document.documentElement.setAttribute('data-a11y-motion', 'true');
      } catch (e) {}
    </script>
  </head>
  <body>
    <div id="scroll-progress" class="scroll-progress"></div>
    <nav class="navbar" transition:persist>
      <div class="container nav-container">
        <a class="brand" href="/">
          <h1>Brad Orego <span class="pronouns">(they/them)</span></h1>
          <h2>UX Leader. User Researcher. Coach. Dancer.</h2>
        </a>
        <div class="nav-actions">
          <a href="/coaching" class="btn btn-outline nav-btn">Coaching</a>
          <a href="https://cal.com/bradorego" class="btn btn-outline nav-btn">Meetings</a>
        </div>
      </div>
    </nav>
    
    <main class="main-content" transition:animate="slide">
      <slot />
    </main>

    <footer class="footer" transition:persist>
      <div class="container text-center">
        <div class="social-links">
          <a href="mailto:hello@bradorego.com" aria-label="Email">
            <i class="ion-android-mail"></i>
          </a>
          <a href="https://twitter.com/bradorego" aria-label="Twitter">
            <i class="ion-social-twitter"></i>
          </a>
          <a href="https://github.com/bradorego" aria-label="GitHub">
            <i class="ion-social-github"></i>
          </a>
          <a href="https://instagram.com/bradorego" aria-label="Instagram">
            <i class="ion-social-instagram"></i>
          </a>
          <a href="https://linkedin.com/in/bradorego" aria-label="LinkedIn">
            <i class="ion-social-linkedin"></i>
          </a>
        </div>
        <div class="rochester-made">
          <a href="http://rochestermade.com" title="Rochester Made">
            <img alt="Rochester Made" src="https://rochestermade.com/media/images/rochester-made-dark-on-light.png" />
          </a>
        </div>
      </div>
    </footer>
    
    <div class="a11y-panel-container">
      <button id="a11y-toggle" class="btn btn-primary a11y-btn" aria-label="Accessibility Options" title="Accessibility Options" style="display: flex; align-items: center; justify-content: center;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
          <circle cx="12" cy="4" r="2"/>
          <path d="M21 9h-6v13h-2v-6h-2v6H9V9H3V7h18v2z"/>
        </svg>
      </button>
      <div id="a11y-menu" class="a11y-menu hidden">
        <h4>Accessibility</h4>
        <label class="a11y-toggle-row">
          <span>Dyslexia-friendly</span>
          <input type="checkbox" id="toggle-dyslexic" />
        </label>
        <label class="a11y-toggle-row">
          <span>High Contrast</span>
          <input type="checkbox" id="toggle-contrast" />
        </label>
        <label class="a11y-toggle-row">
          <span>Reduce Motion</span>
          <input type="checkbox" id="toggle-motion" />
        </label>
      </div>
    </div>

    <script>
      const btn = document.getElementById('a11y-toggle');
      const menu = document.getElementById('a11y-menu');
      
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });

      let settings = {};
      try {
        settings = JSON.parse(localStorage.getItem('a11y') || '{}');
      } catch (e) {}
      
      ['dyslexic', 'contrast', 'motion'].forEach(key => {
        const input = document.getElementById(`toggle-${key}`);
        if (input) {
          input.checked = !!settings[key];
          input.addEventListener('change', (e) => {
            const isChecked = e.target.checked;
            settings[key] = isChecked;
            localStorage.setItem('a11y', JSON.stringify(settings));
            if (isChecked) {
              document.documentElement.setAttribute(`data-a11y-${key}`, 'true');
            } else {
              document.documentElement.removeAttribute(`data-a11y-${key}`);
            }
          });
        }
      });

      // Prevent redundant transitions to the same page
      document.addEventListener('astro:before-preparation', (event) => {
        const from = new URL(event.from.href);
        const to = new URL(event.to.href);
        
        const fromPath = from.pathname.replace(/\/$/, '') || '/';
        const toPath = to.pathname.replace(/\/$/, '') || '/';
        
        if (fromPath === toPath && from.search === to.search) {
          event.preventDefault();
        }
      });
    </script>
    <script>
      /**
       * Scroll Progress Bar Logic
       * This needs to work across ViewTransitions/ClientRouter navigations.
       */
      const updateScrollProgress = () => {
        const progressBar = document.getElementById('scroll-progress');
        if (!progressBar) return;
        
        const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
        progressBar.style.width = scrolled + "%";
      };

      // Initial load
      window.addEventListener('scroll', updateScrollProgress);
      
      // Handle page transitions
      document.addEventListener('astro:page-load', () => {
        updateScrollProgress();
      });
    </script>
    <script>
      // Automatically open external links in a new tab
      document.addEventListener('astro:page-load', () => {
        const links = document.querySelectorAll('a[href^="http"], a[href^="//"]');
        links.forEach(link => {
          if (link.hostname !== window.location.hostname) {
            link.setAttribute('target', '_blank');
            link.setAttribute('rel', 'noopener noreferrer');
          }
        });
      });
    </script>
  </body>
</html>

<style>
  /* Navbar styles */
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(15, 17, 21, 0.85); /* var(--color-bg) with opacity */
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 0;
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  @media (max-width: 768px) {
    .nav-container {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }

  .brand h1 {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }
  
  .brand .pronouns {
    font-size: 1rem;
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .brand h2 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .nav-actions {
    display: flex;
    gap: 0.75rem;
    width: 100%;
  }

  @media (min-width: 769px) {
    .nav-actions {
      width: auto;
    }
  }
  
  .nav-btn {
    flex: 1;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
  }

  /* Main content area */
  .main-content {
    flex: 1;
    padding: 4rem 0;
  }

  /* Footer styles */
  .footer {
    padding: 3rem 0;
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .text-center {
    text-align: center;
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .social-links a {
    color: var(--color-text-muted);
    font-size: 1.75rem;
    transition: all var(--transition-normal);
  }

  .social-links a:hover {
    color: var(--color-primary);
  }

  .rochester-made img {
    height: 40px;
    margin: 0 auto;
    opacity: 0.7;
    transition: opacity var(--transition-normal);
  }

  .rochester-made a:hover img {
    opacity: 1;
  }

  /* Accessibility Panel Styles */
  .a11y-panel-container {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 1000;
  }

  .a11y-btn {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    padding: 0;
    font-size: 1.5rem;
    box-shadow: var(--shadow-md);
  }

  .a11y-menu {
    position: absolute;
    bottom: 4.5rem;
    right: 0;
    width: 250px;
    background: var(--color-bg-offset);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1rem;
    box-shadow: 0 10px 25px -5px rgb(0 0 0 / 0.5);
    transition: opacity var(--transition-normal), transform var(--transition-normal);
  }

  .a11y-menu.hidden {
    opacity: 0;
    pointer-events: none;
    transform: translateY(10px);
  }

  .a11y-menu h4 {
    margin-bottom: 1rem;
    font-size: 1.125rem;
  }

  .a11y-toggle-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
    cursor: pointer;
    font-size: 0.875rem;
    color: var(--color-text);
  }

  .a11y-toggle-row input {
    cursor: pointer;
    width: 1.25rem;
    height: 1.25rem;
  }
</style>
